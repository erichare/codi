# ── Discord bot tokens ────────────────────────────────────────────
# Set one or both. The process will launch a bot instance for each
# token it finds, with the matching personality.
CODI_BOT_TOKEN=
WOOLOO_BOT_TOKEN=

# ── CODI (crypto) personality ─────────────────────────────────────
CRYPTO_API_BASE_URL=https://crypto-predictions-production-6b02.up.railway.app
CODI_COMMAND_PREFIX=!

# ── Wooloo (pokemon + AI) personality ─────────────────────────────
POKEMON_API_BASE_URL=https://pokeapi.co/api/v2
WOOLOO_COMMAND_PREFIX=!
WOOLOO_DEFAULT_MODE=uplift

# Required for Wooloo AI mode. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
